msgstr "``run_drc``、``check_def``、``save_drc``"

#: ../../source/features.rst:103
msgid "**ECO**"
msgstr "**工程变更指令**"

#: ../../source/features.rst:103
msgid "``eco_repair_via``"
msgstr "``eco_repair_via``"

#: ../../source/features.rst:105
msgid "**GUI**"
msgstr "**图形界面**"

